@attribute [Authorize]
@inherits AuthComponentBase

<h3>Dispositivos</h3>

<div @onclick="ClearSelectedCard">
    <div id="deviceControlsWrapper">
        <div>
            <div>
                <div>Grupo de dispositivos</div>
                <div class="text-nowrap">
                    <select class="form-control d-inline" style="width: 150px" @bind="_selectedGroupId">
                        <option value="@_deviceGroupAll">Todos</option>
                        <option value="@_deviceGroupNone">Ninguno</option>
                        @foreach (var group in _deviceGroups)
                        {
                            <option @key="group.ID" value="@group.ID">@group.Name</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-secondary" title="Despertar dispositivos del grupo" style="width: 40px; margin-left: 5px;" @onclick="WakeDevices">
                        <span class="oi oi-power-standby"></span>
                    </button>

                </div>
            </div>

            <div>
                <div class="mt-1">Ordenar</div>
                <select class="form-control d-inline" style="width: 150px" @bind="_selectedSortProperty">
                    <option value=""></option>
                    @foreach (var prop in _sortableProperties)
                    {
                        <option value="@prop.Name">@GetDisplayName(prop)</option>
                    }
                </select>
                <button class="btn btn-sm btn-secondary" title="Dirección de orden" style="width: 40px; margin-left: 5px;" @onclick="ToggleSortDirection">
                    <span class="oi @GetSortIcon()"></span>
                </button>
            </div>

            <div class="custom-control custom-checkbox mt-2">
                <input id="hideOfflineDevicesCheckbox" type="checkbox" class="custom-control-input align-middle" @bind="_hideOfflineDevices" />
                <label class="custom-control-label align-middle" for="hideOfflineDevicesCheckbox">Ocultar dispositivos desconectados</label>
            </div>
            <div class="mt-2">
                <button class="btn btn-sm btn-secondary me-2" @onclick="SelectAllCards">Seleccionar todo</button>
                <button class="btn btn-sm btn-primary" @onclick="HandleRefreshClicked">Actualizar</button>
            </div>
        </div>
         
        <div>
            <div class="d-inline-block text-start">
                <div>
                    <div>Buscar</div>
                    <input class="form-control d-inline"
                           style="width: 200px"
                           placeholder="Buscar propiedades del dispositivo"
                           @bind="_filter" />
                </div>

                <div class="mt-2" style="white-space: nowrap">
                    <button class="btn btn-sm btn-secondary" @onclick="PageDown">
                        <i class="oi oi-chevron-left"></i>
                    </button>
                    <span class="small">Página</span>
                    <input id="currentPageInput" style="width:75px; text-align: center" pattern="[0-9]" @bind="_currentPage" @bind:event="oninput" />
                    <span class="small">de</span>
                    <span>@TotalPages</span>
                    <button class="btn btn-sm btn-secondary" @onclick="PageUp">
                        <i class="oi oi-chevron-right"></i>
                    </button>
                </div>

                <div class="mt-2">
                    <select class="form-control d-inline" style="width:100px" @bind="_devicesPerPage">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                    <span class="ms-1 small">por página</span>
                </div>
            </div>
           

        </div>
    </div>
    <div id="deviceListDiv" class="p-2 mb-5">
        @foreach (var device in DisplayedDevices)
        {
            <CascadingValue Value="this">
                <DeviceCard @key="device.ID" Device="device" />
            </CascadingValue>
        }
    </div>

    <Terminal />
</div>